{
  "name": "whats-new-summary-notifier",
  "version": "0.1.0",
  "bin": {
    "whats-new-summary-notifier": "bin/whats-new-summary-notifier.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "npm run test:ts && npm run test:py",
    "test:ts": "jest",
    "test:py": "uv run --with pytest --with beautifulsoup4 --with boto3 pytest lambda/ -v",
    "lint": "npm run lint:ts && npm run lint:py",
    "lint:ts": "eslint lib/ bin/ test/",
    "lint:py": "uv run --with ruff ruff check lambda/ --per-file-ignores='**/test_*.py:E402'",
    "format": "prettier --write '**/*.{ts,json,md}' --ignore-path .prettierignore && uv run --with ruff ruff format lambda/",
    "cdk": "cdk",
    "dev:console": "cd console && npm run dev"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.0",
    "aws-cdk": "^2.248.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "jest": "^29.7.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.1"
  },
  "dependencies": {
    "@aws-cdk/aws-lambda-python-alpha": "^2.248.0-alpha.0",
    "aws-cdk-lib": "^2.248.0",
    "cdk-nag": "^2.37.55",
    "constructs": "^10.6.0",
    "source-map-support": "^0.5.21"
  }
}
